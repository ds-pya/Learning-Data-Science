when (cursor.getType(i)) {
    Cursor.FIELD_TYPE_STRING -> {
        val columnName = cursor.getColumnName(i)
        val rawValue = cursor.getString(i)

        if (rawValue == null) {
            jsonObject.put(columnName, JSONObject.NULL)
        } else {
            val trimmed = rawValue.trim()
            try {
                // 1. JSON Array 형태 (List<DataClass> 등) 감지
                if (trimmed.startsWith("[")) {
                    jsonObject.put(columnName, JSONArray(trimmed))
                } 
                // 2. JSON Object 형태 (Custom Data Class 등) 감지
                else if (trimmed.startsWith("{")) {
                    jsonObject.put(columnName, JSONObject(trimmed))
                } 
                // 3. 일반 문자열 (URL, 경로 등 포함)
                else {
                    jsonObject.put(columnName, rawValue)
                }
            } catch (e: Exception) {
                // 파싱 에러 시(형식만 [ ]이고 실제론 JSON이 아닐 때) 안전하게 String으로 삽입
                jsonObject.put(columnName, rawValue)
            }
        }
    }
    // Cursor.FIELD_TYPE_INTEGER -> { ... }
}
